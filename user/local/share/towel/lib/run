#!/bin/bash

TOWEL_INI="/etc/distrobox/distrobox.ini"

function inside_towel() {
	[ -n "$CONTAINER_ID" ] && [ "$CONTAINER_ID" = "towel" ] >/dev/null 2>&1
}

function towel_sanity_check() {
	if [ -n "$CONTAINER_ID" ]; then
		builtin echo "Command shouldn't be run inside a container, rerun command on the host system." 1>&2
		exit 1
	fi
}

function towel_exists() {
	podman container exists towel >/dev/null 2>&1
}

function towel_create() {
	towel_sanity_check
	distrobox assemble create --file "$TOWEL_INI"
}

function towel_enter() {
	towel_sanity_check
	if ! towel_exists; then
		builtin echo "No such container towel"
		while builtin read -rp "Create it now? yes|No:"; do
			case "$REPLY" in
			y | yes | Y | Yes | YES)
				towel_create
				break
				;;
			n | no | N | No | NO)
				:
				;;
			*)
				echo "Invalid input." 1>&2
				;;
			esac
			exit 1
		done
	fi
	distrobox enter towel
}

function towel_auto_export() {
	if ! inside_towel; then
		return
	fi
	local bins_regex='/usr/bin/\S+'
	local desktops_regex='/usr/share/applications/\S+\.desktop'
	local files
	files=$(dnf repoquery -l "$1" 2>/dev/null | grep -oE '^('"$bins_regex"'|'"$desktops_regex"')$' 2>/dev/null | sort -u)
	if [ -z "$files" ]; then
		return
	fi
	local desktop_files
	desktop_files=$(grep -E "$desktops_regex" <<<"$files") || true
	if [ -n "$desktop_files" ]; then
		while IFS= read -r desktop_file; do
			if [ -e "$desktop_file" ]; then
				distrobox-export --app "$desktop_file"
				local wrapper_app
				wrapper_app="$HOME/.local/share/applications/towel-$(basename "$desktop_file")"
				if [ -f "$wrapper_app" ]; then
					local exec_line
					exec_line=$(grep "^Exec=" "$wrapper_app" | head -n 1 | sed 's/^Exec=//')
					if [ -n "$exec_line" ]; then
						local exec_escaped
						exec_escaped="${exec_line//\'/\'\\\'\'}"
						local prompt_script="if ! $exec_escaped; then if command -v zenity >/dev/null 2>&1; then zenity --question --text=\"Execution failed. Remove exported app?\"; elif command -v kdialog >/dev/null 2>&1; then kdialog --yesno \"Execution failed. Remove exported app?\"; else exit 1; fi && rm -f \"$wrapper_app\" && update-desktop-database \"$HOME/.local/share/applications\" >/dev/null 2>&1 || true; fi"
						sed -i "s|^Exec=.*|Exec=sh -c '$prompt_script'|g" "$wrapper_app"
					fi
				fi
			fi
		done <<<"$desktop_files"
		return
	fi
	local bin_files
	bin_files=$(grep -E "$bins_regex" <<<"$files") || true
	if [ -n "$bin_files" ]; then
		while IFS= read -r bin_file; do
			if [ -e "$bin_file" ]; then
				distrobox-export --bin "$bin_file"
				local wrapper
				wrapper="$HOME/.local/bin/$(basename "$bin_file")"
				if [ -f "$wrapper" ]; then
					awk '/^	exec / {
						cmd = substr($0, 7)
						printf "\t%s\n", cmd
						printf "\tret=$?\n"
						printf "\tif [ $ret -ne 0 ]; then\n"
						printf "\t\tread -p \"Execution failed. Remove exported app? [y/N] \" ans < /dev/tty 2>/dev/null || true\n"
						printf "\t\tcase \"$ans\" in\n"
						printf "\t\t\t[Yy]*)\n"
						printf "\t\t\t\trm -f \"$0\"\n"
						printf "\t\t\t\t;;\n"
						printf "\t\tesac\n"
						printf "\tfi\n"
						printf "\texit $ret\n"
						next
					}
					{ print }' "$wrapper" >"${wrapper}.tmp" && mv "${wrapper}.tmp" "$wrapper" && chmod +x "$wrapper"
				fi
			fi
		done <<<"$bin_files"
	fi
}

function towel_install() {
	if [ -z "${CONTAINER_ID}" ]; then
		exec distrobox-enter -n towel -- "$HOME/.local/bin/towel" install "$@"
	elif ! inside_towel; then
		exec /usr/bin/distrobox-host-exec "$HOME/.local/bin/towel" install "$@"
	fi
	sudo dnf install "$@" || true
	for pkg in "$@"; do
		towel_auto_export "$pkg"
	done
}

function towel_exec() {
	if [ -z "${CONTAINER_ID}" ]; then
		exec distrobox-enter -n towel -- "$HOME/.local/bin/towel" exec "$@"
	elif ! inside_towel; then
		exec /usr/bin/distrobox-host-exec "$HOME/.local/bin/towel" exec "$@"
	else
		exec "$@"
	fi
}

function towel_remove() {
	towel_sanity_check

	if [ -d "${HOME}/.local/bin" ]; then
		find "${HOME}/.local/bin" -maxdepth 1 -type f -exec grep -q "^# name: towel$" {} \; -delete
	fi

	if [ -d "${HOME}/.local/share/applications" ]; then
		find "${HOME}/.local/share/applications" -maxdepth 1 -name "towel-*.desktop" -type f -delete
		update-desktop-database "${HOME}/.local/share/applications" >/dev/null 2>&1 || true
	fi

	distrobox assemble rm --file "$TOWEL_INI"
}
