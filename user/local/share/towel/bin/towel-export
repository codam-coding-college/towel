#!/usr/bin/env bash

TOWEL_DATA=${TOWEL_DATA:-"$HOME/.local/share/towel"}
TOWEL_BIN_DIR=${TOWEL_BIN_DIR:-"$TOWEL_DATA/bin"}

source "$TOWEL_BIN_DIR/towel-common"

if [ $# -eq 0 ]; then
	builtin echo "No package specified." 1>&2
	exit 1
fi

if [ -z "${CONTAINER_ID}" ]; then
	exec distrobox-enter -n towel -- "$HOME/.local/bin/towel" export "$@"
elif ! inside_towel; then
	exec distrobox-host-exec "$HOME/.local/bin/towel" export "$@"
fi

for pkg in "$@"; do
	towel_auto_export "$pkg"
done
