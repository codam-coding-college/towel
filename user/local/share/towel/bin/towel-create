#!/usr/bin/env bash

TOWEL_DATA=${TOWEL_DATA:-"$HOME/.local/share/towel"}
TOWEL_BIN_DIR=${TOWEL_BIN_DIR:-"$TOWEL_DATA/bin"}

# shellcheck source=user/local/share/towel/bin/towel-common
source "$TOWEL_BIN_DIR/towel-common"

towel_sanity_check
distrobox assemble create --file "$TOWEL_INI" | sed -e 's/^distrobox enter towel$/towel enter/'
