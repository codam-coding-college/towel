#!/usr/bin/env bash

TOWEL_DATA=${TOWEL_DATA:-"$HOME/.local/share/towel"}
TOWEL_BIN_DIR=${TOWEL_BIN_DIR:-"$TOWEL_DATA/bin"}

source "$TOWEL_BIN_DIR/towel-common"

assume_yes=false
install_args=()
while [[ $# -gt 0 ]]; do
	case "$1" in
	-y | --yes)
		assume_yes=true
		;;
	--)
		shift
		while [[ $# -gt 0 ]]; do
			install_args+=("$1")
			shift
		done
		break
		;;
	*)
		install_args+=("$1")
		;;
	esac
	shift
done

if [ ${#install_args[@]} -eq 0 ]; then
	builtin echo "No package specified." 1>&2
	exit 1
fi

if [ -z "${CONTAINER_ID}" ]; then
	if [[ "$assume_yes" == true ]]; then
		exec distrobox-enter -n towel -- "$HOME/.local/bin/towel" install --yes "${install_args[@]}"
	fi
	exec distrobox-enter -n towel -- "$HOME/.local/bin/towel" install "${install_args[@]}"
elif ! inside_towel; then
	if [[ "$assume_yes" == true ]]; then
		exec /usr/bin/distrobox-host-exec "$HOME/.local/bin/towel" install --yes "${install_args[@]}"
	fi
	exec /usr/bin/distrobox-host-exec "$HOME/.local/bin/towel" install "${install_args[@]}"
fi

should_export=false
if [[ "$assume_yes" == true ]]; then
	should_export=true
elif [ -t 0 ]; then
	while builtin read -rp "Export installed apps/binaries to host now? [y/N] " answer; do
		case "$answer" in
		y | yes | Y | Yes | YES)
			should_export=true
			break
			;;
		n | no | N | No | NO | "")
			break
			;;
		*)
			echo "Invalid input." 1>&2
			;;
		esac
	done
else
	builtin echo "Non-interactive install requires --yes to confirm exporting apps to host." 1>&2
	exit 1
fi

sudo dnf install "${install_args[@]}" || true
if [[ "$should_export" == true ]]; then
	for pkg in "${install_args[@]}"; do
		towel_auto_export "$pkg"
	done
fi
