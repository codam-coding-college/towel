#!/usr/bin/env bash

bltins=(builtin cd command continue declare echo exit getopts read return set shift source test trap unalias unset)
enable > /dev/null 2>&1 "${bltins[@]}"
unalias > /dev/null 2>&1 "${bltins[@]}"

set -e

if [ -z "$TOWEL_DATA" ]; then
	if command -v realpath; then
		TOWEL_DATA="$(/usr/bin/dirname "$(/usr/bin/realpath -e "$0")/..")"
	elif command -v readlink; then
		TOWEL_DATA="$(/usr/bin/dirname "$(/usr/bin/readlink -e "$0")/..")"
	else
		echo 1>&2 "Cannot determine script directory. Please ensure realpath or readlink is installed, or set TOWEL_DATA environment variable."
		exit 1
	fi
fi
TOWEL_LIB=${TOWEL_LIB:-"$TOWEL_DATA/lib"}

if [ ! -d "$TOWEL_LIB" ]; then
	echo 1>&2 "Towel library not found at $TOWEL_LIB"
	exit 1
fi

source "$TOWEL_LIB/opts"
source "$TOWEL_LIB/help"
source "$TOWEL_LIB/run"

declare -A arg_handlers=([create]="towel_create" [exec]="towel_exec" [enter]="towel_enter" [export]="towel_export" [install]="towel_install" [remove]="towel_remove")
declare -A opt_handlers=([-h]="print_help")

while [[ $# -gt 0 ]]; do
	arg="$1"
	if [[ " ${!opt_handlers[*]} " == *" $arg "* ]]; then
		handler="${opt_handlers[$arg]}"
		shift
		"$handler" "$@"
	elif [[ " ${!arg_handlers[*]} " == *" $arg "* ]]; then
		shift
		exec "${arg_handlers[$arg]}" "$@"
	else
		[[ "$arg" == -* ]] && unknown_option "$arg" 
		unknown_command "$arg"
		exit 1
	fi
	exec ${arg_handlers[enter]} "$@"
done
