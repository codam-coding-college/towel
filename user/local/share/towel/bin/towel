#!/usr/bin/env bash

declare -ra bltins=(builtin cd continue declare echo exit getopts read return set shift source test trap unalias unset)
enable >/dev/null 2>&1 "${bltins[@]}"
unalias >/dev/null 2>&1 "${bltins[@]}"

# set -e

TOWEL_DATA=${TOWEL_DATA:-"$HOME/.local/share/towel"}
TOWEL_BIN_DIR=${TOWEL_BIN_DIR:-"$TOWEL_DATA/bin"}

if [ ! -d "$TOWEL_BIN_DIR" ]; then
	echo 1>&2 "Towel commands not found at $TOWEL_BIN_DIR"
	exit 1
fi

# shellcheck source=user/local/share/towel/bin/towel-common
source "$TOWEL_BIN_DIR/towel-common"

function print_help() {
	"$TOWEL_BIN_DIR/towel-help"
}

function print_version() {
	local version_file="$TOWEL_DATA/VERSION"
	if [ -f "$version_file" ]; then
		printf 'towel %s\n' "$(cat "$version_file")"
	else
		echo "towel (unknown version)" 1>&2
	fi
}

function unknown_command() {
	echo 1>&2 "Unknown command \`towel $1'"
	echo 1>&2 "Try \`towel -h'"
	exit 1
}

function unknown_option() {
	echo 1>&2 "Unknown option \`towel $1'"
	echo 1>&2 "Try \`towel -h'"
	exit 1
}

towel_auto_update_check

if [ $# -eq 0 ]; then
	exec "$TOWEL_BIN_DIR/towel-enter"
fi

cmd="$1"
shift
case "$cmd" in
-h | --help)
	print_help
	;;
-v | --version)
	print_version
	;;
create | exec | enter | export | install | remove | update)
	"$TOWEL_BIN_DIR/towel-$cmd" "$@"
	;;
-*)
	unknown_option "$cmd"
	;;
*)
	unknown_command "$cmd"
	;;
esac
